# ============================================================
# AI FDE 助手 - 生产环境配置示例
# 部署到宝塔面板时，复制本文件为 .env 并填写真实值
# ============================================================

# ───────────────────────────────────
# 1. HTTP 服务配置
# ───────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ───────────────────────────────────
# 2. LLM / AI 接口配置
# ───────────────────────────────────
#   API Key（必填，填入你的真实 Key）
LLM_API_KEY=your-deepseek-api-key-here

#   API Base URL（默认 DeepSeek，以下为可选方案）
#   DeepSeek  : https://api.deepseek.com/v1 （默认推荐）
#   豆包(Doubao)  : https://ark.cn-beijing.volces.com/api/v3
#   通义千问    : https://dashscope.aliyuncs.com/compatible-mode/v1
#   Ollama 本地: http://127.0.0.1:11434/v1
LLM_API_BASE=https://api.deepseek.com/v1

#   模型名称（根据提供商选择）
#   DeepSeek: deepseek-chat / deepseek-reasoner
#   豆包:    ep-xxxx（接入点 ID）
#   Ollama:  qwen2.5 / deepseek-r1 等本地模型名
LLM_MODEL=deepseek-chat

#   是否允许把事件摘要发送给外部 LLM（设为 true 才启用 AI 增强功能）
LLM_SEND_EVENTS=true
#   单次调用 token 预算（超出时自动降级）
LLM_MAX_TOKENS=2048

# ───────────────────────────────────
# 3. OCR 接口配置
# ───────────────────────────────────
#   provider 取值：
#     local     - 本地轻量解析（不上传截图，仅用文本摘要，部署最简便，推荐）
#     external  - 第三方 OCR（需另起 Python OCR 服务或使用腾讯云 OCR）
#     mock      - 返回占位文本，仅用于开发调试
OCR_PROVIDER=local

#   可选：切换为 external 模式（腾讯云 OCR / 自建 OCR 服务）
#   将 OCR_PROVIDER 改为 external 后，填写以下配置：
#   - 腾讯云 OCR: https://ocr.tencentcloudapi.com/
#   - 自建 OCR:  http://127.0.0.1:9003 （对应 paddle_ocr_service/ocr_server.py）
# OCR_API_ENDPOINT=http://127.0.0.1:9003
# OCR_API_KEY=

# ───────────────────────────────────
# 4. 会话/日志
# ───────────────────────────────────
DATA_DIR=.data
LOG_LEVEL=info
