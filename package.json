{
  "name": "ai-workflow-observer-agent",
  "version": "0.1.0",
  "description": "观察型 AI 工作流定制 Agent：先观察工作，再生成定制 Agent 蓝图",
  "private": true,
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node --max-old-space-size=2048 dist/server/index.js",
    "dev": "tsx watch src/server/index.ts",
    "demo": "tsx src/scripts/run-demo.ts",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('.data',{recursive:true,force:true})\"",
    "docker:build": "docker build -t ai-workflow-observer .",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:deploy": "bash scripts/deploy.sh",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@types/imap": "^0.8.43",
    "@types/nodemailer": "^8.0.1",
    "@types/xlsx": "^0.0.35",
    "bcrypt": "^6.0.0",
    "express": "^4.19.2",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vitest": "^4.1.10"
  }
}
