# ============================================================
# 观察型 AI 工作流定制 Agent —— 配置示例文件
# 👉 使用方法：复制为 .env 或直接在启动前放置于项目根目录
# ⚠ 本文件仅为示例，不要把真实密钥写进来；真实密钥应放于本地 .env（已在 .gitignore 中忽略）
# ============================================================

# ───────────────────────────────────
# 1. HTTP 服务配置
# ───────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# ───────────────────────────────────
# 2. LLM / AI 接口配置（⚠ 需要接入真实模型时必填）
# ───────────────────────────────────
#   ⚠ 【API Key 标注位置 1/3】模型提供商的 API Key
#   示例（OpenAI 兼容协议，适用于 DeepSeek / Qwen / 豆包 / 本地 Ollama 等）
LLM_API_KEY=your-llm-api-key-here

#   ⚠ 【API Key 标注位置 2/3】API Base URL
#   OpenAI 官方 ：https://api.openai.com/v1
#   DeepSeek    ：https://api.deepseek.com/v1
#   本地 Ollama  ：http://127.0.0.1:11434/v1
LLM_API_BASE=https://api.deepseek.com/v1

#   ⚠ 【API Key 标注位置 3/3】模型名称
#   例如 gpt-4o-mini / deepseek-chat / deepseek-reasoner / qwen-plus
LLM_MODEL=deepseek-chat

#   可选：是否允许把事件摘要发送给外部 LLM（默认 false，显式 true 才启用 AI 增强）
LLM_SEND_EVENTS=false
#   可选：单次调用 token 预算（超出时自动降级为本地 mock）
LLM_MAX_TOKENS=2048

# ───────────────────────────────────
# 3. OCR 接口配置（可选，接入真实屏幕识别时使用）
# ───────────────────────────────────
#   provider 取值：
#     local     —— 本地轻量解析（不上传截图，仅用文本摘要）
#     external  —— 第三方 OCR（需填 API Key / endpoint）
#     mock      —— 返回占位文本，用于开发调试
OCR_PROVIDER=local
#   若 OCR_PROVIDER=external，填对应 Key（⚠ 【API Key 标注位置 4/3】OCR 服务 API Key）
OCR_API_KEY=
OCR_API_ENDPOINT=

# ───────────────────────────────────
# 4. 会话/日志
# ───────────────────────────────────
DATA_DIR=.data
LOG_LEVEL=info

# ───────────────────────────────────
# 5. Docker 部署配置
# ───────────────────────────────────
NODE_ENV=production
SERVER_HOST=0.0.0.0

# ───────────────────────────────────
# 6. Redis 缓存配置（可选）
# ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
